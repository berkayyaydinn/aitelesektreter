# LiveKit
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Backend internal API
BACKEND_BASE_URL=http://localhost:5000
INTERNAL_API_KEY=change-me-shared-secret

# Provider seçimi (swappable) — değer değiştir, kod değişmez
STT_PROVIDER=whisper           # whisper(self-host) | deepgram | azure | openai
LLM_PROVIDER=local             # local/openai_compatible(self-host) | openai(bulut)
TTS_PROVIDER=piper             # piper(self-host) | azure | elevenlabs | openai

# Türkçe dil
SPEECH_LANGUAGE=tr

# ── Gecikme / diyalog akıcılığı ────────────────────────────────────────────
# multilingual: model tabanlı sıra tespiti (önerilen, Türkçe destekli) | vad: yalnız sessizlik
TURN_DETECTION=multilingual
MIN_ENDPOINTING_DELAY=0.4      # kullanıcı sustuktan sonra en az bu kadar bekle (sn)
MAX_ENDPOINTING_DELAY=5.0      # model "devam edecek" dese de en çok bu kadar bekle (sn)
TOOL_TIMEOUT_SECONDS=4         # konuşma içi backend araç çağrısı timeout'u (ölü hava sınırı)

# Provider anahtarları (sadece seçtiklerini doldur)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
ELEVENLABS_API_KEY=

# LLM model
# LLM_PROVIDER=local  → self-host model adı (vLLM'de servis edilen ad / Ollama tag). Bkz. docs/llm-setup.md
# LLM_PROVIDER=openai → gpt-4o-mini gibi bulut model
LLM_MODEL=Qwen2.5-14B-Instruct

# ── Yerel / OpenAI-uyumlu LLM (LLM_PROVIDER=local|openai_compatible) ────────
# OpenAI-uyumlu /v1 uç (vLLM / Ollama / LM Studio). Boş bırakılırsa gerçek OpenAI kullanılır.
LLM_BASE_URL=http://llm:8000/v1
LLM_API_KEY=sk-local           # yerel sunucuda genelde önemsiz; vLLM --api-key ile eşleşmeli

# TTS ses (bulut sağlayıcılar)
AZURE_TTS_VOICE=tr-TR-EmelNeural
ELEVENLABS_VOICE_ID=

# ── Self-host STT/TTS (OpenAI-uyumlu yerel sunucular) ──────────────────────
# STT_PROVIDER=whisper / TTS_PROVIDER=piper iken kullanılır.
STT_BASE_URL=http://whisper-stt:8000/v1
STT_API_KEY=sk-local
WHISPER_MODEL=small            # CPU: tiny|base|small (int8). GPU varsa medium|large-v3
TTS_BASE_URL=http://piper-tts:8000/v1
TTS_API_KEY=sk-local
PIPER_MODEL=piper
PIPER_VOICE=tr_TR-dfki-medium

# ── Çağrı kaydı (opsiyonel, self-host MinIO'ya audio-only OGG) ─────────────
# RoomComposite egress headless Chrome çalıştırır → CPU-only VPS'te ağır. Pilotta aç.
RECORDING_ENABLED=false
RECORDING_S3_ENDPOINT=http://minio:9000
RECORDING_S3_BUCKET=telesekreter-recordings
RECORDING_S3_ACCESS_KEY=minioadmin
RECORDING_S3_SECRET=change-me-minio-secret
RECORDING_S3_REGION=us-east-1
