# --- Veritabanı ---
# Lokal test (varsayılan): SQLite, Postgres/Docker gerektirmez.
DB_PROVIDER=sqlite                # sqlite | postgres
SQLITE_PATH=Data Source=telesekreter.db
# DB_PROVIDER=postgres ise (self-hosted DB: infra/compose ile ayağa kaldır):
# Username/Password/Database değerleri infra/compose/.env ile eşleşmeli.
DATABASE_URL=Host=127.0.0.1;Port=5432;Database=telesekreter;Username=telesekreter;Password=change-me-strong-postgres-pw

# voice-agent <-> backend ortak sır (X-Internal-Key)
INTERNAL_API_KEY=change-me-shared-secret
# Opsiyonel: tenant'a kısıtlı admin anahtarları "guid:key,guid:key" (boş = sadece master).
INTERNAL_TENANT_KEYS=
# Rate limit: anahtar/IP başına istek/sn (varsayılan 50).
RATE_LIMIT_PER_SECOND=50

# --- Mesajlaşma ---
# Lokal test (varsayılan): console = dry-run, Meta gerektirmez (log'a yazar).
MESSAGING_PROVIDER=console        # console | whatsapp_cloud

# MESSAGING_PROVIDER=whatsapp_cloud ise Meta WhatsApp Cloud API:
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_APPOINTMENT=randevu_onayi

# --- SMS (hatırlatma) ---
# Lokal test (varsayılan): console = dry-run, Netgsm gerektirmez (log'a yazar).
SMS_PROVIDER=console              # console | netgsm
# SMS_PROVIDER=netgsm ise Netgsm HTTP SMS API:
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=                 # Netgsm'de onaylı gönderici başlığı

# --- Netsantral Custom (Özel) API webhook (gelen çağrı yönlendirme) ---
# Netsantral PBX çağrıda /netsantral/inbound'a POST atar; bu uç tenant'ı bulup çağrıyı
# NETSANTRAL_AGENT_DID'e yönlendirir (SIP-trunk → LiveKit → voice-agent). Detay: docs/netsantral-setup.md
NETSANTRAL_WEBHOOK_TOKEN=            # Netsantral fonksiyonunda "statik değişken" olarak tanımla (sabit sır)
NETSANTRAL_AGENT_DID=               # SIP-trunk'a bağlı iç yönlendirme numarası (AI ajanın oturduğu DID)

# --- Hatırlatma dağıtıcısı (arka plan) ---
REMINDERS_ENABLED=true           # false -> arka plan döngüsü kapalı
REMINDER_SCAN_INTERVAL_MINUTES=5
REMINDER_APPOINTMENT_LEAD_HOURS=24   # randevudan kaç saat önce hatırlatma
REMINDER_QUIET_START=09:00       # TR yerel — bu saatten önce gönderme
REMINDER_QUIET_END=21:00         # TR yerel — bu saatten sonra gönderme
REMINDER_REQUIRE_CONSENT=true    # false -> rıza kontrolü yapma (yalnız test)

# --- Ses hattı: giden arama (Netgsm SIP — hat gelince) ---
OUTBOUND_DIALER=console          # console | livekit
NETGSM_SIP_OUTBOUND_TRUNK_ID=
# LiveKit (giden SIP arama için): voice-agent ile aynı değerler
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- CRM aynalama (Mirbal CRM entegrasyonu) ---
# Lokal test (varsayılan): none = kapalı. Randevu/sipariş/çağrı olayları CRM'e gönderilmez.
CRM_PROVIDER=none                 # none | mirbal
# CRM_PROVIDER=mirbal ise: Mirbal CRM kök URL'i + X-Api-Key.
# API anahtarı CRM tarafında AppSettings["CrmApiKey"] ile birebir eşleşmeli.
CRM_BASE_URL=https://localhost:5001
CRM_API_KEY=
