# infra/compose/.env — DB container kimlik bilgileri. KOPYALA: cp .env.example .env
# Bu dosyayı (.env) ASLA commit etme. Güçlü, benzersiz şifreler kullan.

# --- PostgreSQL (ai-telesekreter backend) ---
POSTGRES_USER=telesekreter
POSTGRES_PASSWORD=change-me-strong-postgres-pw
POSTGRES_DB=telesekreter

# --- MySQL (Mirbal CRM) ---
# NOT: Eski sızan şifreyi (DeCostle@DB#2024) KULLANMA — yenisini üret, eskisini uzak host'ta döndür.
MYSQL_ROOT_PASSWORD=change-me-strong-mysql-root-pw
MYSQL_DATABASE=mirbal
MYSQL_USER=mirbal
MYSQL_PASSWORD=change-me-strong-mysql-pw

# --- Ortak iç servis sırrı (backend <-> voice-agent, X-Internal-Key) ---
INTERNAL_API_KEY=change-me-shared-secret
# Opsiyonel: tenant'a kısıtlı admin anahtarları "guid:key,guid:key" (boş = sadece master key).
INTERNAL_TENANT_KEYS=
# Rate limit: anahtar/IP başına istek/sn (kötüye kullanım kapısı).
RATE_LIMIT_PER_SECOND=50

# --- Backend mesajlaşma + CRM (opsiyonel) ---
MESSAGING_PROVIDER=console        # console | whatsapp_cloud
CRM_PROVIDER=none                 # none | mirbal
CRM_BASE_URL=
CRM_API_KEY=

# --- Backend SMS + hatırlatma (Netgsm) ---
SMS_PROVIDER=console              # console | netgsm
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=
REMINDERS_ENABLED=true
REMINDER_SCAN_INTERVAL_MINUTES=5
REMINDER_APPOINTMENT_LEAD_HOURS=24
REMINDER_QUIET_START=09:00
REMINDER_QUIET_END=21:00
REMINDER_REQUIRE_CONSENT=true

# --- Backend giden arama (Netgsm SIP — hat gelince) ---
OUTBOUND_DIALER=console           # console | livekit
NETGSM_SIP_OUTBOUND_TRUNK_ID=

# --- LiveKit (self-host) ---
# Boş bırakılırsa voice-agent iç ağda ws://livekit:7880 kullanır (compose default).
# Cloud kullanmak istersen LIVEKIT_URL'i wss://... olarak doldur.
# Anahtar üret: docker run --rm livekit/livekit-server generate-keys
LIVEKIT_URL=
LIVEKIT_API_KEY=change-me-livekit-key
LIVEKIT_API_SECRET=change-me-livekit-secret
SPEECH_LANGUAGE=tr
STT_PROVIDER=whisper              # whisper(self-host) | deepgram | azure | openai
LLM_PROVIDER=openai              # bulut beyin — self-host edilmez
TTS_PROVIDER=piper               # piper(self-host) | azure | elevenlabs | openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Self-host STT/TTS (yerel OpenAI-uyumlu sunucular — compose içinde çalışır)
STT_BASE_URL=http://whisper-stt:8000/v1
STT_API_KEY=sk-local
WHISPER_MODEL=small               # CPU: tiny|base|small (int8). GPU: medium|large-v3
TTS_BASE_URL=http://piper-tts:8000/v1
TTS_API_KEY=sk-local
PIPER_MODEL=piper
PIPER_VOICE=tr_TR-dfki-medium

# Bulut sağlayıcı geri dönüş kapısı (opsiyonel)
DEEPGRAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
AZURE_TTS_VOICE=tr-TR-EmelNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Çağrı kaydı (opsiyonel: MinIO + livekit-egress) ---
# RECORDING_ENABLED=true ise agent audio-only egress başlatır (CPU ağır — pilotta aç).
RECORDING_ENABLED=false
RECORDING_S3_ENDPOINT=http://minio:9000
RECORDING_S3_BUCKET=telesekreter-recordings
RECORDING_S3_ACCESS_KEY=minioadmin
RECORDING_S3_SECRET=change-me-minio-secret
RECORDING_S3_REGION=us-east-1

# --- Yedek ---
BACKUP_RETENTION_DAYS=7
